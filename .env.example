# Private key for deploying and interacting with contracts (DO NOT commit real keys)
PRIVATE_KEY=
WALLET_ADDRESS=

# Onchain OS API Credentials
OK_ACCESS_KEY=your_api_key_here
OK_ACCESS_SECRET=your_secret_key_here
OK_ACCESS_PASSPHRASE=your_passphrase_here

# Chain Configuration
CHAIN_ID=196
RPC_URL=https://rpc.xlayer.tech

# Safety Defaults (change to enable live trading)
GENESIS_PAUSED=true
GENESIS_MODE=paper
GENESIS_DRY_RUN=true

# === V2 Ecosystem Expansion ===

# Moltbook Identity Integration
MOLTBOOK_API_KEY=
MOLTBOOK_APP_KEY=
MOLTBOOK_BASE_URL=https://www.moltbook.com
MOLTBOOK_IDENTITY_REQUIRED=false
MOLTBOOK_TRUST_BONUS_BPS=50

# Data Integrity Verification
DATA_INTEGRITY_ENABLED=true
DATA_INTEGRITY_MAX_DEVIATION_BPS=500
DATA_INTEGRITY_MAX_STALENESS=300
DATA_INTEGRITY_MIN_SOURCES=2

# Strategy Licensing
STRATEGY_LICENSE_ENABLED=true
STRATEGY_LICENSE_PROTOCOL_FEE_BPS=500
STRATEGY_LICENSE_TREASURY=

# V1 Contract Addresses (required for V2 deployment)
ASSEMBLER_ADDRESS=
STRATEGY_NFT_ADDRESS=
TREASURY_ADDRESS=

# V2 Contract Addresses (filled after deployment)
DATA_INTEGRITY_MODULE_ADDRESS=
MOLTBOOK_IDENTITY_MODULE_ADDRESS=
STRATEGY_LICENSE_ADDRESS=
